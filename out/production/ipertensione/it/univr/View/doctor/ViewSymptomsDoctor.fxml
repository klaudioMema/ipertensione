<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" stylesheets="@../Main.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.univr.Controller.doctor.ViewSymptomsDoctor">
    <BorderPane prefHeight="400.0" prefWidth="600.0">
        <center>
            <TableView fx:id="tableView" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
                <columns>
                    <TableColumn fx:id="nameColumn" prefWidth="90.0" text="Name" />
                    <TableColumn fx:id="descriptionColumn" prefWidth="293.0" text="Description" />
                    <TableColumn fx:id="startColumn" prefWidth="107.0" text="Start" />
                    <TableColumn fx:id="endColumn" prefWidth="108.0" text="End" />
                </columns>
            </TableView>
        </center>
        <bottom>
            <Pane prefHeight="181.0" prefWidth="600.0" style="-fx-background-color: linear-gradient(from 25% 25% to 100% 100%, #2265c3, #d62dfd);;" BorderPane.alignment="CENTER">
                <Label layoutX="25.0" layoutY="6.0" styleClass="normal" text="Report Symptoms" textFill="WHITE">
                    <font>
                        <Font size="25.0" />
                    </font>
                </Label>
                <TextField fx:id="nameField" layoutX="30.0" layoutY="50.0" prefHeight="25.0" prefWidth="195.0" promptText="Name" />
                <DatePicker fx:id="startField" layoutX="30.0" layoutY="90.0" prefHeight="25" prefWidth="195" promptText="When did it start?" />
                <DatePicker fx:id="endField" layoutX="30.0" layoutY="130.0" prefHeight="25" prefWidth="195" promptText="When did it finished?" />
                <TextArea fx:id="descriptionField" layoutX="230.0" layoutY="50.0" prefHeight="104.0" prefWidth="190.0" promptText="Describe what did you feel" />
                <Button fx:id="addButton" layoutX="423.0" layoutY="44.0" mnemonicParsing="false" onAction="#addSymptom" prefHeight="63.0" prefWidth="176.0" text="ADD" textFill="WHITE" />
                <Button layoutX="424.0" layoutY="102.0" mnemonicParsing="false" onAction="#removeSelected" prefHeight="70.0" prefWidth="173.0" text="Remove Selected" textFill="WHITE" />
                <Label fx:id="statusLabel" layoutX="230.0" layoutY="-1.0" prefHeight="50.0" prefWidth="369.0" styleClass="normal" visible="false" text="Couldn't remove data" textFill="#ffdada">
                    <font>
                        <Font size="25.0" />
                    </font>
                </Label>
            </Pane>
        </bottom>
    </BorderPane>
</AnchorPane>
