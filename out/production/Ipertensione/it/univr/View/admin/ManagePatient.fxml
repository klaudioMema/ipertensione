<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<Pane prefHeight="400.0" prefWidth="427.0" stylesheets="@../Main.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.univr.Controller.admin.ManagePatient">
    <Label id="titleLabel" layoutX="53.0" layoutY="6.0" prefHeight="53.0" prefWidth="339.0" styleClass="titles" text="Manage Patient">
        <font>
            <Font name="Arial Black" size="35.0" />
        </font>
    </Label>
    <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#80878d" height="327.0" layoutX="13.0" layoutY="59.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" width="402.0" />
    <Label layoutX="31.0" layoutY="130.0" styleClass="normal" text="Name" textFill="WHITE">
        <font>
            <Font size="18.0" />
        </font>
    </Label>
    <Label layoutX="31.0" layoutY="170.0" styleClass="normal" text="Surname" textFill="WHITE">
        <font>
            <Font size="18.0" />
        </font>
    </Label>
    <Label layoutX="32.0" layoutY="210.0" styleClass="normal" text="Codice Fiscale" textFill="WHITE">
        <font>
            <Font size="18.0" />
        </font>
    </Label>
    <TextField fx:id="nameField" layoutX="170.0" layoutY="130.0" prefHeight="25.0" prefWidth="149.0" promptText="Patient's name" />
    <TextField fx:id="surnameField" layoutX="170.0" layoutY="170.0" prefHeight="25.0" prefWidth="149.0" promptText="Patient's surname" />
    <TextField fx:id="codiceFField" layoutX="170.0" layoutY="210.0" promptText="Codice Fiscale" />
    <Label fx:id="statusLabel" layoutX="79.0" layoutY="272.0" prefHeight="32.0" prefWidth="287.0" text="Result" visible="false" wrapText="true">
        <font>
            <Font size="22.0" />
        </font>
    </Label>
    <Button layoutX="300.0" layoutY="322.0" mnemonicParsing="false" onAction="#searchPatient" prefHeight="43.0" prefWidth="113.0" text="Search" textFill="WHITE">
        <font>
            <Font size="14.0" />
        </font></Button>
    <Button layoutX="20.0" layoutY="322.0" mnemonicParsing="false" onAction="#changeData" prefHeight="43.0" prefWidth="113.0" text="Change Data" textFill="#f5f5f5">
        <font>
            <Font size="14.0" />
        </font></Button>
    <Button layoutX="160.0" layoutY="322.0" mnemonicParsing="false" onAction="#changeDoctor" prefHeight="43.0" prefWidth="113.0" text="Change Doctor" textFill="WHITE">
        <font>
            <Font size="14.0" />
        </font></Button>
    <Button layoutX="289.0" layoutY="69.0" mnemonicParsing="false" onAction="#removePatient" prefHeight="30.0" prefWidth="120.0" text="Remove Patient" textFill="#fc8c8c">
        <font>
            <Font size="14.0" />
        </font>
    </Button>
</Pane>
