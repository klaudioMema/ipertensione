<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" stylesheets="@../Main.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.univr.Controller.doctor.Prescriptions">
   <BorderPane prefHeight="400.0" prefWidth="600.0">
      <center>
         <TableView fx:id="tableView" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
            <columns>
               <TableColumn fx:id="medicationColumn" prefWidth="168.5" text="Medication" />
               <TableColumn fx:id="indicationsColumn" prefWidth="239.5" text="Indications" />
               <TableColumn fx:id="daysColumn" prefWidth="51.0" text="Days" />
               <TableColumn fx:id="fromDateColumn" prefWidth="139.0" sortType="DESCENDING" text="From" />
            </columns>
         </TableView>
      </center>
      <bottom>
         <Pane prefHeight="181.0" prefWidth="600.0" style="-fx-background-color: linear-gradient(from 25% 25% to 100% 100%, #2265c3, #d62dfd);;" BorderPane.alignment="CENTER">
            <Label layoutX="25.0" layoutY="6.0" styleClass="normal" text="Add a new therapy" textFill="WHITE">
               <font>
                  <Font size="25.0" />
               </font>
            </Label>
            <TextField fx:id="medicationField" layoutX="30.0" layoutY="50.0" prefHeight="25.0" prefWidth="195.0" promptText="Medication" />
            <TextField fx:id="daysField" layoutX="250.0" layoutY="50.0" prefHeight="25.0" prefWidth="193.0" promptText="Days" />
            <TextArea fx:id="indicationsField" layoutX="30.0" layoutY="90.0" prefHeight="80.0" prefWidth="200.0" promptText="Indications" />
            <Button layoutX="470.0" layoutY="90.0" mnemonicParsing="false" onAction="#removeSelected" prefHeight="80.0" prefWidth="120.0" text="Remove Selected" textFill="WHITE" />
            <Button layoutX="250.0" layoutY="90.0" mnemonicParsing="false" onAction="#addTherapy" prefHeight="80.0" prefWidth="200.0" text="ADD" textFill="WHITE" />
            <Label fx:id="statusLabel" layoutX="280.0" layoutY="-1.0" prefHeight="50.0" prefWidth="327.0" styleClass="normal" text="Couldn't remove therapy" textFill="#ffdada" visible="false">
               <font>
                  <Font size="25.0" />
               </font>
            </Label>
         </Pane>
      </bottom>
   </BorderPane>
</AnchorPane>
