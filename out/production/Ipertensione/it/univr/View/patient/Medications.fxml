<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" stylesheets="@../Main.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.univr.Controller.patient.Medications">
    <BorderPane prefHeight="400.0" prefWidth="600.0">
        <center>
            <TableView fx:id="tableView" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
                <columns>
                    <TableColumn fx:id="medicationColumn" prefWidth="168.5" text="Medication" />
                    <TableColumn fx:id="indicationsColumn" prefWidth="239.5" text="Indications" />
                    <TableColumn fx:id="daysLeftColumn" prefWidth="51.0" text="Days" />
                    <TableColumn fx:id="untilDateColumn" prefWidth="139.0" sortType="DESCENDING" text="Start Date" />
                </columns>
            </TableView>
        </center>
        <bottom>
            <Pane prefHeight="181.0" prefWidth="600.0" style="-fx-background-color: linear-gradient(from 25% 25% to 100% 100%, #2265c3, #d62dfd);;" BorderPane.alignment="CENTER">
                <Label fx:id="todayLabel" layoutX="25.0" layoutY="10.0" prefHeight="36.0" prefWidth="568.0" styleClass="normal" text="Medications I have to take today" textFill="WHITE">
                    <font>
                        <Font size="25.0" />
                    </font>
                </Label>
                <Button layoutX="380.0" layoutY="60.0" mnemonicParsing="false" onAction="#reportMedicine" prefHeight="100.0" prefWidth="200.0" text="Report as taken" textFill="WHITE" />
                <Label fx:id="statusLabel" layoutX="25.0" layoutY="46.0" prefHeight="50.0" prefWidth="392.0" styleClass="normal" text="Couldn't remove therapy" textFill="#ffdada">
                    <font>
                        <Font size="25.0" />
                    </font>
                </Label>
            </Pane>
        </bottom>
    </BorderPane>
</AnchorPane>
