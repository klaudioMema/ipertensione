<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" stylesheets="@../Main.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.univr.Controller.doctor.DoctorViewDashboard">
    <HBox fx:id="contentArea" layoutX="145.0" prefHeight="400.0" prefWidth="455.0" />
    <VBox prefHeight="400.0" prefWidth="144.0" style="-fx-background-color: #77dd77;">
        <Pane prefHeight="102.0" prefWidth="174.0">
            <Label fx:id="usernameLabel" layoutX="5.0" layoutY="36.0" text="USERNAME">
                <font>
                    <Font size="24.0" />
                </font>
            </Label>
        </Pane>
        <Button mnemonicParsing="false" prefHeight="45.0" prefWidth="144.0" styleClass="menuItem" text="Home" />
        <Button mnemonicParsing="false" onAction="#searchPatient" prefHeight="45.0" prefWidth="144.0" styleClass="menuItem" text="Cerca Paziente" />
        <Button mnemonicParsing="false" onAction="#myPatient" prefHeight="45.0" prefWidth="144.0" styleClass="menuItem" text="Paziente " />
      <Button mnemonicParsing="false" onAction="#Alert" prefHeight="45.0" prefWidth="145.0" styleClass="menuItem" text="Alerts" />
        
        <Button mnemonicParsing="false" onAction="#logoutEvent" prefHeight="45.0" prefWidth="145.0" styleClass="menuItem" text="Logout" />
    </VBox>
</AnchorPane>
