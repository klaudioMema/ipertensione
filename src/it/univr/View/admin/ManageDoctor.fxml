<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<Pane prefHeight="400.0" prefWidth="427.0" stylesheets="@../Main.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.univr.Controller.admin.ManageDoctor">
    <Label id="titleLabel" alignment="TOP_CENTER" layoutX="53.0" prefHeight="53.0" prefWidth="339.0" styleClass="titles" text="Gestisci Dottore">
        <font>
            <Font name="Arial Black" size="35.0" />
        </font>
    </Label>
    <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#80878d" height="327.0" layoutX="13.0" layoutY="59.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" width="402.0" />
    <Label layoutX="31.0" layoutY="130.0" styleClass="normal" text="Nome" textFill="WHITE">
        <font>
            <Font size="18.0" />
        </font>
    </Label>
    <Label layoutX="31.0" layoutY="170.0" styleClass="normal" text="Cognome" textFill="WHITE">
        <font>
            <Font size="18.0" />
        </font>
    </Label>
    <Label layoutX="32.0" layoutY="210.0" styleClass="normal" text="Email" textFill="WHITE">
        <font>
            <Font size="18.0" />
        </font>
    </Label>
    <TextField fx:id="nameField" layoutX="148.0" layoutY="128.0" prefHeight="25.0" prefWidth="149.0" promptText="Nome Dottore" />
    <TextField fx:id="surnameField" layoutX="148.0" layoutY="168.0" prefHeight="25.0" prefWidth="149.0" promptText="Cognome Dottore" />
    <TextField fx:id="emailField" layoutX="148.0" layoutY="211.0" promptText="Email Dottore" />
    <Label fx:id="statusLabel" layoutX="79.0" layoutY="272.0" prefHeight="32.0" prefWidth="287.0" text="Result" visible="false" wrapText="true">
        <font>
            <Font size="22.0" />
        </font>
    </Label>
    <Button layoutX="244.0" layoutY="322.0" mnemonicParsing="false" onAction="#searchDoctor" prefHeight="43.0" prefWidth="113.0" text="Cerca">
        <font>
            <Font size="14.0" />
        </font></Button>
    <Button layoutX="80.0" layoutY="322.0" mnemonicParsing="false" onAction="#saveButton" prefHeight="43.0" prefWidth="113.0" text="Salva">
        <font>
            <Font size="14.0" />
        </font></Button>
    <Button layoutX="140.0" layoutY="273.0" mnemonicParsing="false" onAction="#removeDoctor" prefHeight="30.0" prefWidth="149.0" text="Rimuovi Dottore">
        <font>
            <Font size="14.0" />
        </font>
    </Button>
</Pane>
